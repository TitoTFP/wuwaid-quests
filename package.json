{
  "name": "wuwaid-quests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-check.js && concurrently -k -n web,api -c blue,green \"cd web && vite\" \"uv run uvicorn app.main:app --reload --reload-dir app --port 8000 --app-dir .\"",
    "dev:web": "cd web && vite",
    "dev:api": "uv run uvicorn app.main:app --reload --reload-dir app --port 8000 --app-dir .",
    "build": "cd web && vite build",
    "preview": "cd web && vite preview",
    "serve": "node scripts/serve-check.js && uv run uvicorn app.main:app --port 8000 --app-dir .",
    "build:index": "python scripts/build_index.py"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "react-window": "^1.8.10"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
